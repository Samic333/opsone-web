# CrewAssist Portal Configuration
# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────────
APP_NAME=CrewAssist Portal
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_KEY=CHANGE-THIS-TO-A-RANDOM-32CHARS!

# ── Deployment Mode ──────────────────────────────────
# "multi_tenant" = SaaS mode (multiple airlines)
# "single_tenant" = dedicated instance (one airline)
APP_MODE=multi_tenant
FIXED_TENANT_ID=

# ── Database ─────────────────────────────────────────
# Use "sqlite" for local dev, "mysql" for production
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=crewassist
DB_USERNAME=crewassist
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── Session ──────────────────────────────────────────
SESSION_LIFETIME=120
SESSION_SECURE=true

# ── API ──────────────────────────────────────────────
API_TOKEN_EXPIRY_HOURS=168
API_RATE_LIMIT=60

# ── File Uploads ─────────────────────────────────────
UPLOAD_MAX_SIZE=52428800
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,gif

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=warning
LOG_FILE=storage/logs/app.log

# ── Docker (used by docker-compose.yml) ──────────────
PORTAL_PORT=8080
DB_EXTERNAL_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
